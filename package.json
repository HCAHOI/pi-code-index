{
  "name": "pi-code-index",
  "version": "0.1.0",
  "type": "module",
  "description": "Local semantic codebase index for pi: chunks + embeds your repo and exposes a semantic_code_search tool to find code by intent. LanceDB + tree-sitter, incremental on-change reindex, .index_tag filtering.",
  "license": "MIT",
  "author": "Chiyu Hao (https://github.com/HCAHOI)",
  "homepage": "https://github.com/HCAHOI/pi-code-index",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HCAHOI/pi-code-index.git"
  },
  "bugs": {
    "url": "https://github.com/HCAHOI/pi-code-index/issues"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "semantic-search",
    "code-index",
    "embeddings",
    "lancedb",
    "tree-sitter"
  ],
  "scripts": {
    "check": "tsc --noEmit",
    "clean": "rm -rf node_modules package-lock.json",
    "eval": "node scripts/eval.mjs"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.30.0",
    "chokidar": "^5.0.0",
    "fast-glob": "^3.3.3",
    "ignore": "^7.0.5",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "^0.20.8"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.3"
  }
}
